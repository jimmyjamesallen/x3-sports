---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import BookingWizard from '../components/BookingWizard.tsx';
---

<Layout title="Book Your Free Trial | X3 Sports">
  <PageHeader
    heading="Book Your Free Trial"
    subheading="Pick a class, choose a time, and start training — completely free."
  />

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <BookingWizard client:load />
    </div>
  </section>
</Layout>
