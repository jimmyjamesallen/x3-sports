---
interface Props {
  heading?: string;
  subheading?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  heading = "Ready to Start Training?",
  subheading = "Join X3 Sports today and get your first week free. No commitment, no experience necessary.",
  ctaText = "Claim Your Free Trial",
  ctaLink = "/free-trial",
} = Astro.props;
---

<section class="py-20 px-6 bg-gradient-to-br from-accent/10 via-bg to-accent/5">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{heading}</h2>
    <p class="text-text-muted text-lg mb-8 leading-relaxed">{subheading}</p>
    <a
      href={ctaLink}
      class="inline-block bg-accent hover:bg-accent-hover text-white font-semibold px-8 py-4 rounded-lg text-lg transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>
